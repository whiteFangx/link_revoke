# Get these free from https://my.telegram.org (API development tools).
# Required just to start the control bot — used for both the control bot
# and, later, your own account login via /session.
API_ID=12345678
API_HASH=your_api_hash_here

# Create this bot with @BotFather on Telegram, copy the token it gives you.
# This is the "control bot" you message to run /session and check /status.
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your own numeric Telegram user ID (send /start to @userinfobot to get it).
# Locks the control bot so only you can use /session, /status, /clearlink, /cancel.
OWNER_ID=your_numeric_telegram_id

# Leave this blank the first time — /session fills it in automatically once
# you log in. On future restarts, if this is already set, the userbot
# activates automatically without needing /session again.
SESSION_STRING=
